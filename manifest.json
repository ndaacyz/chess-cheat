{
  "manifest_version": 3,
  "name": "Lichess Auto Stockfish Arrow",
  "version": "1.0",
  "description": "Auto analysis + arrow real-time di Lichess",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://lichess.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://lichess.org/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["stockfish.js", "stockfish.wasm"],
      "matches": ["<all_urls>"]
    }
  ]
}
